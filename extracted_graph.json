    },
    {
      "source_id": "accounts",
      "target_id": "contracts",
      "label": "JOINS_WITH",
      "properties": {
        "join_condition": "contracts.account_id = accounts.account_id"
      }
    },
    {
      "source_id": "accounts",
      "target_id": "usage_ledger",
      "label": "JOINS_WITH",
      "properties": {
        "join_condition": "usage_ledger.account_id = accounts.account_id"
      }
    },
    {
      "source_id": "contracts",
      "target_id": "invoices",
      "label": "JOINS_WITH",
      "properties": {
