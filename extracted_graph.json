    {
      "id": "organizations.is_test_account",
      "label": "Column",
      "properties": {
        "data_type": "INT",
        "description": "Flag indicating test (1) vs real (0) account."
      }
    },
    {
      "id": "accounts",
      "label": "Table",
      "properties": {
        "description": "CRM sub‑entity representing a department or regional account within an organization."
      }
