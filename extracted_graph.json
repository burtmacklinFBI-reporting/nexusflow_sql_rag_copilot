    {
      "id": "organizations",
      "label": "Table",
      "properties": {
        "description": "Parent company level entity containing organization details such as name, industry, and test account flag."
      }
    },
    {
      "id": "organizations.org_id",
      "label": "Column",
      "properties": {
        "data_type": "INT",
