    },
    {
      "id": "payments.status_code",
      "label": "Column",
      "properties": {
        "data_type": "INT",
        "description": "Numeric payment state (0=Failed, 1=Settled, 2=Refunded)."
      }
    },
    {
      "id": "sales_reps",
